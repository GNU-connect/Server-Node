          "legendFormat": "P95(ms)",
          "range": true
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "(1 - (sum(rate(http_errors_total{job=\"app\"}[5m])) / (sum(rate(http_requests_total{job=\"app\"}[5m])) + 0.001))) * 100",
          "legendFormat": "가용성(%)",
          "range": true
